<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>Burkina Services Connect (BSC) | Landing Pages qui vendent en Afrique</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Space+Grotesk:wght@500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Space Grotesk', 'Oswald', sans-serif;
      background: #0a0a0a;
      color: #fff;
      line-height: 1.3;
      overflow-x: hidden;
      scroll-behavior: smooth;
    }

    .container {
      max-width: 600px;
      margin: 0 auto;
      padding: 0 18px;
    }

    :root {
      --red: #e52e2e;
      --dark: #0a0a0a;
      --orange: #f97316;
      --white: #ffffff;
      --card-bg: #141414;
      --border-dark: #2a2a2a;
    }

    h1, h2, h3 {
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: -0.02em;
    }

    /* TITRES AVEC RÉVÉLATION (clip-path 5sec) */
    h2 {
      clip-path: inset(0 100% 0 0);
      transition: clip-path 5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    h2.visible {
      clip-path: inset(0 0% 0 0);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      text-decoration: none;
      border-radius: 12px;
      transition: all 0.2s ease;
      cursor: pointer;
      font-family: 'Space Grotesk', sans-serif;
      text-align: center;
      border: none;
      letter-spacing: 0.03em;
      position: relative;
      overflow: hidden;
    }

    .btn-primary {
      background: var(--red);
      color: white;
      padding: 18px 28px;
      font-size: 1.25rem;
      box-shadow: 0 10px 25px rgba(229, 46, 46, 0.5);
      border: 1px solid rgba(255,255,255,0.15);
      width: fit-content;
      animation: softGlow 2.5s ease-in-out infinite; /* pulsation douce au lieu de shake */
    }

    @keyframes softGlow {
      0%   { box-shadow: 0 10px 25px rgba(229,46,46,0.4); }
      50%  { box-shadow: 0 10px 40px rgba(229,46,46,0.75); }
      100% { box-shadow: 0 10px 25px rgba(229,46,46,0.4); }
    }

    .btn-primary:hover {
      background: #c62828;
      transform: scale(1.04);
      box-shadow: 0 15px 35px rgba(229, 46, 46, 0.8);
    }

    .btn-secondary {
      background: transparent;
      color: var(--white);
      border: 2px solid var(--white);
      padding: 14px 24px;
      font-size: 1rem;
      font-weight: 700;
      background: rgba(255,255,255,0.05);
    }

    /* Animations premium lentes (5s) */
    .fade-up {
      opacity: 0;
      transform: translate3d(0, 60px, 0);
      transition: opacity 5s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-up.visible { opacity: 1; transform: translate3d(0, 0, 0); }

    .zoom-in {
      opacity: 0;
      transform: scale(0.88);
      transition: opacity 5s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .zoom-in.visible { opacity: 1; transform: scale(1); }

    .slide-left {
      opacity: 0;
      transform: translate3d(-60px, 0, 0);
      transition: opacity 5s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .slide-left.visible { opacity: 1; transform: translate3d(0, 0, 0); }

    .slide-right {
      opacity: 0;
      transform: translate3d(60px, 0, 0);
      transition: opacity 5s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .slide-right.visible { opacity: 1; transform: translate3d(0, 0, 0); }

    .parallax-bg {
      background-attachment: fixed;
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
    }

    .card {
      background: var(--card-bg);
      border-radius: 22px;
      padding: 24px 18px;
      border: 1px solid var(--border-dark);
      transition: transform 0.25s, border-color 0.2s;
    }
    .card:hover {
      transform: translateY(-4px);
      border-color: #555;
    }

    .price-tag {
      font-size: 2.3rem;
      font-weight: 800;
      color: var(--orange);
      margin: 8px 0;
    }

    .unsplash-img {
      width: 100%;
      height: 180px;
      object-fit: cover;
      border-radius: 18px;
      margin: 15px 0;
      border: 1px solid #333;
      will-change: transform;
    }

    .floating-img {
      animation: floatImage 4s ease-in-out infinite;
    }

    @keyframes floatImage {
      0% { transform: translateY(0px); }
      50% { transform: translateY(-8px); }
      100% { transform: translateY(0px); }
    }

    /* Sticky CTA + WhatsApp : correction chevauchement */
    .sticky-cta {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 999;
      width: calc(100% - 36px);
      max-width: 420px;
      background: var(--red);
      color: white;
      font-weight: 800;
      font-size: 1.2rem;
      padding: 16px 20px;
      border-radius: 60px;
      text-align: center;
      box-shadow: 0 12px 30px rgba(229,46,46,0.6);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: 1px solid rgba(255,255,255,0.3);
      backdrop-filter: blur(12px);
      animation: stickyPulse 2.4s infinite;
    }

    @keyframes stickyPulse {
      0% { box-shadow: 0 12px 30px rgba(229,46,46,0.6); }
      50% { box-shadow: 0 8px 22px rgba(229,46,46,1); }
      100% { box-shadow: 0 12px 30px rgba(229,46,46,0.6); }
    }

    .whatsapp-float {
      position: fixed;
      bottom: 90px;
      right: 20px;
      background: #25D366;
      color: white;
      border-radius: 50%;
      width: 60px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      box-shadow: 0 8px 25px rgba(37,211,102,0.6);
      z-index: 1000;
      text-decoration: none;
      border: 2px solid white;
      transition: 0.2s;
    }
    .whatsapp-float:hover {
      transform: scale(1.08);
    }

    .badge-urgence {
      background: var(--orange);
      color: black;
      font-weight: 800;
      padding: 8px 16px;
      border-radius: 30px;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin: 10px 0;
    }

    .countdown {
      background: #1e1e1e;
      border: 1px solid var(--red);
      border-radius: 14px;
      padding: 12px 16px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-weight: 700;
      color: var(--orange);
      margin: 12px 0;
    }

    /* STYLE ACCORDEON FAQ */
    details {
      background:#1a1a1a;
      border-radius:14px;
      margin-bottom:12px;
      overflow:hidden;
      transition: all 0.2s;
    }
    details[open] {
      border-left:3px solid var(--orange);
    }
    summary {
      padding:16px 20px;
      font-weight:700;
      cursor:pointer;
      list-style:none;
      display:flex;
      justify-content:space-between;
      align-items:center;
    }
    summary::-webkit-details-marker {
      display:none;
    }
    summary::after {
      content:'▼';
      font-size:0.75rem;
      color:var(--orange);
      transition:transform 0.3s;
    }
    details[open] summary::after {
      transform:rotate(180deg);
    }
    .faq-body {
      padding:0 20px 16px;
      color:#aaa;
      border-top:1px solid #2a2a2a;
      padding-top:12px;
      line-height:1.6;
    }

    @media (max-width: 400px) {
      .btn-primary { font-size: 1rem; padding: 16px 16px; }
      .whatsapp-float { bottom: 90px; right: 16px; width: 54px; height: 54px; font-size: 28px; }
    }

    .list-stagger > * {
      transition-delay: 0s;
    }
  </style>
</head>
